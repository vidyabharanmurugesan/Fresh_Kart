# ============================================
# FreshKart — Environment Variables Template
# ============================================
# Copy this file: cp .env.example .env

# ── Frontend Configuration ──
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=FreshKart
VITE_APP_VERSION=1.0.0

# ── Backend Configuration ──
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
DATABASE_URL=sqlite:///database/local_auth.db
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=http://localhost:5173
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# Phase 2
FIREBASE_CREDENTIALS_PATH=config/firebase-service-account.json
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# SOCKETIO_CORS_ORIGINS=http://localhost:5173
# VITE_SOCKET_URL=http://localhost:5000

